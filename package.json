    "simulate": "pnpm --filter @jaycode/ingest simulate",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "dotenv": "^16.4.5"
  },
  "engines": { "node": ">=20" },
  "packageManager": "pnpm@9.12.0"
}
