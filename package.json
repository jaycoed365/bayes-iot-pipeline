{
  "name": "bayes-iot-pipeline",
  "private": true,
  "version": "0.1.0",
  "description": "End-to-end IoT pipeline with Bayesian time-series forecasting",
  "scripts": {
    "dev:ingest": "pnpm --filter @jaycode/ingest dev",
